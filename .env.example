# Database (Supabase Postgres connection string)
DATABASE_URL=
DIRECT_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin allowlist (comma-separated emails)
ADMIN_EMAILS=you@example.com

# --- Contact form email (Resend: https://resend.com) ---
# API key: Resend Dashboard → API Keys
RESEND_API_KEY=re_xxxxxxxx

# Sender — MUST use a verified domain in Resend (Domains → verify DNS)
# Production example:
#   EMAIL_FROM=Portfolio <notify@yourdomain.com>
# Testing only (sends to your Resend account email):
#   EMAIL_FROM=Portfolio <onboarding@resend.dev>
EMAIL_FROM=

# Optional: inbox for contact alerts (defaults to ADMIN_EMAILS if empty)
NOTIFY_EMAIL=you@example.com

# Production site URL (SEO, sitemap, robots, Open Graph, email links)
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
