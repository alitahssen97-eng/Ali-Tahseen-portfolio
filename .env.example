# Prisma → Supabase Postgres (required for: npx prisma db push)
# Supabase Dashboard → Project Settings → Database → Connection string
#   • Transaction pooler (6543)  → DATABASE_URL
#   • Session / Direct (5432)    → DIRECT_URL
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Client (Auth, Storage, Realtime)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
# Service role (server only — never expose to the browser). Used for profile image upload.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Admin panel — comma-separated emails allowed to access /admin
ADMIN_EMAILS="your-email@example.com"

# Email notifications when visitors submit the contact form (Resend: https://resend.com)
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="onboarding@resend.dev"
# Optional — defaults to ADMIN_EMAILS if omitted
NOTIFY_EMAIL="your-email@example.com"
# Public site URL for links in notification emails
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
